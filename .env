NODE_ENV=production

# Database Configuration
DB_ROOT_PASSWORD=your_mysql_root_password
DB_NAME=myuzima_db
DB_USER=myuzima_user
DB_PASSWORD=myuzima_password

# Security & API Secrets
JWT_SECRET=a_very_long_and_random_jwt_secret_key
ENCRYPTION_KEY=a_32_character_long_random_encryption_key

# OAuth Configuration (for Admin Login)
VITE_APP_ID=your_oauth_app_id
OAUTH_SERVER_URL=your_oauth_server_url
OWNER_OPEN_ID=your_admin_user_openid
OWNER_NAME=Your Admin Name

# Forge API (if applicable)
BUILT_IN_FORGE_API_URL=your_forge_api_url
BUILT_IN_FORGE_API_KEY=your_forge_api_key
FRONTEND_FORGE_API_URL=your_frontend_forge_api_url
FRONTEND_FORGE_API_KEY=your_frontend_forge_api_key
